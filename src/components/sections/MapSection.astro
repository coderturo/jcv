---
import MapComponent from "../ui/MapSection";
import { Bus, Check } from "lucide-react";
---

<section class="mx-2 md:m-8 px-2 md:p-8 mb-12">
  <div class="flex flex-col lg:flex-row gap-0 lg:gap-8">
    <!-- Texto izquierdo -->
    <div class="flex-1 flex flex-col justify-center min-h-0">
      <h2 class="font-heading text-4xl md:text-6xl font-semibold">
        No te pierdas
      </h2>
      <p
        class="mt-2 text-[18px] md:text-[20px] text-[#3D2608] font-medium italic"
      >
        Estamos más cerca de lo que imaginas
      </p>
      <p
        class="mt-3 sm:mt-4 md:mt-5 xl:mt-6 text-[17px] sm:text-[18px] md:text-[17px] lg:text-[19px] xl:text-[20px] leading-[1.35] sm:leading-[1.3] md:leading-tight xl:leading-[1.22] text-foreground/85"
      >
        Encuéntranos fácilmente y planifica tu visita sin complicaciones.
        Estamos listos para recibirte con los brazos abiertos.
      </p>

      <!-- Referencias -->
      <div class="mt-5 xl:mt-7.5">
        <p class="font-bold text-[17px] sm:text-[18px] xl:text-[20px] mb-3">
          Referencias:
        </p>
        <div class="flex flex-wrap gap-3">
          <a
            href="https://maps.app.goo.gl/uQ3qgjfjzhQ6n91K9"
            target="_blank"
            rel="noopener noreferrer"
          >
            <!-- Plaza Vea -->
            <div
              class="flex items-center border-2 border-[#3D2608] rounded-full bg-[#FE0000] cursor-pointer select-none active:scale-95 transition-transform overflow-hidden"
            >
              <div class="flex items-center justify-center px-3 py-2 shrink-0">
                <Check size={18} strokeWidth={4} className="text-[#FFF703]" />
              </div>
              <div class="border-l-2 border-[#3D2608] bg-[#F8E4D0] px-3 py-2">
                <span
                  class="font-heading font-bold text-[15px] sm:text-[16px] text-brand-black"
                >
                  Plaza Vea – Colonial
                </span>
              </div>
            </div>
          </a>

          <a
            href="https://maps.app.goo.gl/PfTPhAJCNKj3TXXh6"
            target="_blank"
            rel="noopener noreferrer"
          >
            <!-- Paradero San José -->
            <div
              class="flex items-center border-2 border-[#3D2608] rounded-full bg-white cursor-pointer select-none active:scale-95 transition-transform overflow-hidden"
            >
              <div class="flex items-center justify-center px-3 py-2 shrink-0">
                <Bus size={18} strokeWidth={3} className="text-[#2B7FFF]" />
              </div>
              <div class="border-l-2 border-[#3D2608] bg-[#F8E4D0] px-3 py-2">
                <span
                  class="font-heading font-bold text-[15px] sm:text-[16px] text-brand-black"
                >
                  Paradero San José
                </span>
              </div>
            </div>
          </a>
        </div>
      </div>
    </div>

    <!-- Mapa derecho -->
    <div class="flex-1 w-full mt-4 lg:mt-0 shadow-xl">
      <MapComponent client:load />
    </div>
  </div>
</section>
