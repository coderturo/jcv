---
import { Button } from "../ui/button";
---

<section class="px-6 py-10 md:px-8 md:py-14 overflow-hidden">
  <div
    class="min-h-72 md:h-112.5 rounded-xl flex justify-center items-center p-8 md:p-12bg-cover bg-center"
    style="background-image:linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0) 200%), url('/images/Testing.webp')"
  >
    <div class="text-center flex flex-col items-center gap-4 max-w-2xl">
      <h2 class="font-heading text-2xl md:text-4xl font-semibold text-white">
        ¿Hay algo en tu corazón?
      </h2>
      <p class="text-sm md:text-base font-medium text-white">
         Comparte tu petición con nosotros y oremos juntos.
         Dios puede traer paz, dirección y esperanza a tu vida.
      </p>
      <a href="/ministerios/varones">
        <Button size="lg" className="font-bold px-10 py-6 text-lg">Oremos</Button>
      </a>
    </div>
  </div>
</section>
